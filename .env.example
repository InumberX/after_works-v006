# Build-time public environment variables (inlined into the bundle by Next.js).
# On Cloudflare these are provided by the GitHub Actions workflow from the
# GitHub Environment variables; copy this file to `.env.local` for local dev.

# Canonical site origin, e.g. https://afterworks.jp
NEXT_PUBLIC_SITE_URL=
# Site root path (usually "/")
NEXT_PUBLIC_SITE_ROOT=
# Display name of the site
NEXT_PUBLIC_SITE_NAME=
# Headless CMS (Kuroco) API base URL
NEXT_PUBLIC_API_URL=
# Google Analytics measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# Static image directory base
NEXT_PUBLIC_STATIC_IMAGE_DIR=
