{
  "name": "@InumberX/afterworks-v006",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint . --max-warnings=0",
    "lint-fix": "oxlint --fix .",
    "stylelint": "stylelint './{src,.storybook}/**/*.{css,scss,sass}'",
    "stylelint-fix": "stylelint --fix './{src,.storybook}/**/*.{css,scss,sass}'",
    "format": "oxfmt --check './{src,.storybook}/**/*.{js,jsx,ts,tsx}'",
    "format-fix": "oxfmt './{src,.storybook}/**/*.{js,jsx,ts,tsx}'",
    "typecheck": "tsc -b",
    "test": "vitest",
    "storybook": "storybook dev --no-open -p 6006 -c .storybook",
    "storybook-build": "storybook build -c .storybook",
    "upgrade": "npx npm-check-updates -u",
    "upgrade-check": "npx npm-check-updates",
    "pre-commit": "npm run typecheck && npm run lint-fix && npm run stylelint-fix && npm run format-fix"
  },
